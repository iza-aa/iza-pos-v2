@startuml
title ERD IZA POS - Core Business Data

hide circle
skinparam linetype ortho
skinparam classAttributeIconSize 0

entity staff {
  * id : uuid
  --
  name : text
  role : text
  status : text
  passcode_hash : text
}

entity customers {
  * id : uuid
  --
  name : text
  phone/email : text
  points : numeric
}

entity categories {
  * id : uuid
  --
  name : text
}

entity products {
  * id : uuid
  --
  category_id : uuid
  name : text
  type : text
  price : numeric
  available/is_available : boolean
}

entity variant_groups {
  * id : uuid
  --
  name : text
}

entity variant_options {
  * id : uuid
  --
  variant_group_id : uuid
  name : text
  price_delta : numeric
}

entity product_variant_groups {
  * id : uuid
  --
  product_id : uuid
  variant_group_id : uuid
}

entity recipes {
  * id : uuid
  --
  product_id : uuid
}

entity recipe_ingredients {
  * id : uuid
  --
  recipe_id : uuid
  inventory_item_id : uuid
  quantity_needed : numeric
  unit : text
  cost_behavior : text
}

entity product_variant_recipe_adjustments {
  * id : uuid
  --
  product_id : uuid
  variant_option_id : uuid
  inventory_item_id : uuid
  adjustment_quantity : numeric
  notes : text
}

entity menu_bundles {
  * id : uuid
  --
  name : text
  bundle_price : numeric
  is_active : boolean
  display_order : numeric
}

entity menu_bundle_items {
  * id : uuid
  --
  bundle_id : uuid
  product_id : uuid
  quantity : numeric
}

entity floors {
  * id : uuid
  --
  name : text
}

entity tables {
  * id : uuid
  --
  floor_id : uuid
  table_number/name : text
  status : text
  qr_token : text
}

entity table_sessions {
  * id : uuid
  --
  table_id : uuid
  customer_id : uuid
  status : text
  started_at : timestamptz
  ended_at : timestamptz
}

entity orders {
  * id : uuid
  --
  customer_id : uuid
  table_session_id : uuid
  table_id : uuid
  created_by : uuid
  total : numeric
  discount : numeric
  status : text
  payment_status : text
  payment_method : text
  created_at : timestamptz
  completed_at : timestamptz
}

entity order_items {
  * id : uuid
  --
  order_id : uuid
  product_id : uuid
  product_name : text
  quantity : numeric
  total_price : numeric
  status : text
  ready_at : timestamptz
  served_at : timestamptz
  served_by : uuid
}

entity payment_transactions {
  * id : uuid
  --
  order_id : uuid
  amount : numeric
  method : text
  status : text
}

entity rewards {
  * id : uuid
  --
  name : text
  discount_type : text
  discount_value : numeric
  points_required : numeric
  is_active : boolean
}

entity customer_reward_redemptions {
  * id : uuid
  --
  customer_id : uuid
  reward_id : uuid
  order_id : uuid
  status : text
}

entity customer_point_transactions {
  * id : uuid
  --
  customer_id : uuid
  order_id : uuid
  points : numeric
  transaction_type : text
}

entity inventory_items {
  * id : uuid
  --
  name : text
  category : text
  current_stock : numeric
  reorder_level : numeric
  unit : text
  cost_per_unit : numeric
  tracking_mode : text
  station_scope : text
  par_level : numeric
}

entity inventory_batches {
  * id : uuid
  --
  inventory_item_id : uuid
  batch_number : text
  supplier : text
  quantity_received : numeric
  quantity_remaining : numeric
  unit_cost : numeric
  received_at : timestamptz
  expiry_date : date
  receipt_url : text
}

entity inventory_batch_movements {
  * id : uuid
  --
  inventory_batch_id : uuid
  inventory_item_id : uuid
  movement_type : text
  quantity : numeric
  quantity_before : numeric
  quantity_after : numeric
}

entity usage_transactions {
  * id : uuid
  --
  order_id : uuid
  staff_id : uuid
  transaction_type/type : text
  total_cost : numeric
  created_at : timestamptz
}

entity usage_transaction_details {
  * id : uuid
  --
  usage_transaction_id : uuid
  inventory_item_id : uuid
  quantity_used : numeric
  unit_cost : numeric
  total_cost : numeric
}

entity kitchen_station_batches {
  * id : uuid
  --
  inventory_item_id : uuid
  source_batch_id : uuid
  station_status : text
  quantity_received : numeric
  quantity_remaining : numeric
  unit_cost : numeric
  expiry_date : date
}

entity kitchen_station_movements {
  * id : uuid
  --
  station_batch_id : uuid
  inventory_item_id : uuid
  source_batch_id : uuid
  usage_transaction_id : uuid
  movement_type : text
  quantity : numeric
  total_cost : numeric
  shift_name : text
}

entity kitchen_station_shift_counts {
  * id : uuid
  --
  inventory_item_id : uuid
  business_date : date
  shift_name : text
  opening_quantity : numeric
  transfer_in_quantity : numeric
  pos_usage_quantity : numeric
  waste_quantity : numeric
  physical_closing_quantity : numeric
}

entity stock_reports {
  * id : uuid
  --
  material_name : text
  inventory_item_id : uuid
  report_type : text
  status : text
  reported_by_role : text
  station_scope : text
  notes : text
}

entity shifts {
  * id : uuid
  --
  name : text
  start_time : time
  end_time : time
}

entity attendance {
  * id : uuid
  --
  staff_id : uuid
  shift_id : uuid
  attendance_date : date
  clock_in_at : timestamptz
  clock_out_at : timestamptz
  check_in_status : text
  check_out_status : text
}

entity staff_shift_weekly_assignments {
  * id : uuid
  --
  staff_id : uuid
  shift_id : uuid
  weekday : numeric
}

entity staff_shift_daily_assignments {
  * id : uuid
  --
  staff_id : uuid
  shift_id : uuid
  business_date : date
}

entity store_settings {
  * id : uuid
  --
  setting_key : text
  setting_value : text
}

entity presensi_shift {
  * id : uuid
  --
  staff_id : uuid
  tanggal : date
  created_at : timestamptz
}

entity presence_code {
  * id : uuid
  --
  code : text
  expires_at : timestamptz
  created_at : timestamptz
}

entity bookkeeping_entries {
  * id : uuid
  --
  source_type : text
  source_id : uuid
  entry_type : text
  amount : numeric
  business_date : date
  status : text
}

entity bookkeeping_exceptions {
  * id : uuid
  --
  source_type : text
  source_id : uuid
  status : text
  note : text
}

entity bookkeeping_expenses {
  * id : uuid
  --
  expense_date : date
  category : text
  amount : numeric
  receipt_url : text
  status : text
}

entity bookkeeping_shift_closings {
  * id : uuid
  --
  staff_id : uuid
  shift_id : uuid
  business_date : date
  expected_cash : numeric
  actual_cash : numeric
  status : text
}

entity bookkeeping_daily_closings {
  * id : uuid
  --
  business_date : date
  status : text
  closed_by : uuid
}

entity bookkeeping_reports {
  * id : uuid
  --
  report_type : text
  period_start : date
  period_end : date
  generated_by : uuid
}

entity bookkeeping_financial_settings {
  * id : uuid
  --
  setting_key : text
  setting_value : text
}

entity order_corrections {
  * id : uuid
  --
  order_id : uuid
  status : text
  physical_status : text
  note : text
}

entity activity_logs {
  * id : uuid
  --
  user_id : uuid
  user_name : text
  user_role : text
  action : text
  action_category : text
  action_description : text
  resource_type : text
  resource_id : uuid
  resource_name : text
  severity : text
  tags : text
  changes_summary : text
  created_at : timestamptz
}

categories ||--o{ products : has
products ||--o{ recipes : has
recipes ||--o{ recipe_ingredients : contains
inventory_items ||--o{ recipe_ingredients : used_by
products ||--o{ product_variant_groups : has
variant_groups ||--o{ product_variant_groups : assigned
variant_groups ||--o{ variant_options : has
variant_options ||--o{ product_variant_recipe_adjustments : adjusts
products ||--o{ product_variant_recipe_adjustments : has
inventory_items ||--o{ product_variant_recipe_adjustments : affects

menu_bundles ||--o{ menu_bundle_items : contains
products ||--o{ menu_bundle_items : bundled

floors ||--o{ tables : contains
tables ||--o{ table_sessions : opens
customers ||--o{ table_sessions : starts
customers ||--o{ orders : places
table_sessions ||--o{ orders : groups
tables ||--o{ orders : served_at
staff ||--o{ orders : creates
orders ||--o{ order_items : contains
products ||--o{ order_items : ordered
staff ||--o{ order_items : serves
orders ||--o{ payment_transactions : paid_by

customers ||--o{ customer_reward_redemptions : redeems
rewards ||--o{ customer_reward_redemptions : redeemed
orders ||--o{ customer_reward_redemptions : applied_to
customers ||--o{ customer_point_transactions : earns
orders ||--o{ customer_point_transactions : source

inventory_items ||--o{ inventory_batches : stocked_as
inventory_items ||--o{ inventory_batch_movements : moves
inventory_batches ||--o{ inventory_batch_movements : logs
orders ||--o{ usage_transactions : causes
staff ||--o{ usage_transactions : records
usage_transactions ||--o{ usage_transaction_details : details
inventory_items ||--o{ usage_transaction_details : deducted

inventory_items ||--o{ kitchen_station_batches : prepared_as
inventory_batches ||--o{ kitchen_station_batches : source
kitchen_station_batches ||--o{ kitchen_station_movements : logs
inventory_items ||--o{ kitchen_station_movements : moves
inventory_batches ||--o{ kitchen_station_movements : source
usage_transactions ||--o{ kitchen_station_movements : linked_usage
inventory_items ||--o{ kitchen_station_shift_counts : counted
inventory_items ||--o{ stock_reports : reported

staff ||--o{ attendance : attends
shifts ||--o{ attendance : scheduled
staff ||--o{ staff_shift_weekly_assignments : weekly
staff ||--o{ staff_shift_daily_assignments : daily
shifts ||--o{ staff_shift_weekly_assignments : assigned
shifts ||--o{ staff_shift_daily_assignments : assigned
staff ||--o{ presensi_shift : records

staff ||--o{ bookkeeping_shift_closings : submits
shifts ||--o{ bookkeeping_shift_closings : closes
staff ||--o{ bookkeeping_daily_closings : closes
staff ||--o{ bookkeeping_reports : generates
orders ||--o{ order_corrections : corrected
bookkeeping_entries }o..|| orders : source
bookkeeping_entries }o..|| usage_transactions : source
bookkeeping_entries }o..|| bookkeeping_expenses : source
bookkeeping_exceptions }o..|| order_corrections : source

staff ||--o{ activity_logs : user

@enduml
