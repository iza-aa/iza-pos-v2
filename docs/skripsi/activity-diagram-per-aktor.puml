@startuml
title Activity Diagram - Owner

start
:Owner login;
:Buka owner dashboard;
fork
  :Review overview bisnis;
  :Analisis revenue, order, AOV, payment, business health;
fork again
  :Review sales dashboard;
  :Analisis COGS, margin, menu profitability;
fork again
  :Review customer dashboard;
  :Analisis member, guest, reward, loyalty insight;
fork again
  :Review inventory dashboard;
  :Analisis stock status, batch risk, movement, staff report;
fork again
  :Review staff dashboard;
  :Analisis attendance, late, overtime, productivity;
fork again
  :Review operation dashboard;
  :Analisis order flow, service time, completion/cancel;
end fork

if (Butuh rekomendasi AI?) then (ya)
  :Generate owner recommendation;
  :Simpan/lihat insight;
endif

if (Butuh export laporan?) then (ya)
  :Export dashboard Excel/PDF sesuai modul;
endif

if (Ada exception/report/closing?) then (ya)
  :Buka bookkeeping;
  :Review auto ledger, expense, exception, shift closing;
  if (Valid?) then (ya)
    :Approve/resolve;
  else (tidak)
    :Reject/reopen/adjust ledger;
  endif
endif

if (Butuh kelola staff?) then (ya)
  :Buka staff manager;
  :Tambah/edit staff, generate passcode, atur shift;
endif

if (Butuh promo/reward/bundle?) then (ya)
  :Buka customer discount section;
  :Create/update reward discount atau menu bundle;
endif

:Pantau notification dan activity log;
stop
@enduml

@startuml
title Activity Diagram - Manager

start
:Manager login;
:Buka fitur operasional manager;

fork
  :Kelola menu;
  :CRUD kategori dan produk;
  :Atur variant group/option;
  :Upload foto menu;
fork again
  :Kelola inventory;
  :Tambah/update raw material;
  :Restock batch dengan supplier, expiry, receipt;
  if (Ada koreksi stok?) then (ya)
    :Input stock adjustment dengan alasan;
    :Catat usage transaction dan batch movement;
  endif
  :Atur recipe dan variant recipe adjustment;
  :Review usage history;
  :Review stock reports dari staff;
fork again
  :Kelola order;
  :Pantau order aktif;
  :Update status order/order item;
  if (Ada koreksi order?) then (ya)
    :Buat correction/cancel/refund;
    :Catat order_corrections dan adjustment bila perlu;
    :Catat exception/activity log;
  endif
fork again
  :Kelola table/floor;
  :CRUD floor dan meja;
  :Generate/regenerate QR table;
  :Update status/posisi meja;
fork again
  :Kelola staff/reward/bookkeeping operations;
  :Pantau staff dan attendance;
  :Kelola reward bila diperlukan;
  :Lihat shift closing/expense operational;
end fork

:Pantau manager notification;
stop
@enduml

@startuml
title Activity Diagram - Staff

start
:Staff login dengan passcode;
:Buka fitur operasional staff;

if (Mulai shift?) then (ya)
  :Clock in / presensi;
endif

if (Role kasir/barista menerima order langsung?) then (ya)
  :Buka POS;
  :Pilih product dan variant;
  :Buat order;
  :Proses payment;
  :Simpan orders, order_items, payment_transactions;
endif

:Buka order board;
:Pantau order aktif;
if (Ada cancel/refund/koreksi pesanan?) then (ya)
  :Ajukan order correction;
  :Catat order_corrections dan activity log;
endif
if (Item sudah dibuat?) then (ya)
  :Update item/order status;
  :Catat ready_at/served_at;
endif

if (Order selesai dan perlu deduct stock?) then (ya)
  :Generate usage_transactions;
  :Generate usage_transaction_details;
  :Update inventory atau kitchen ready stock sesuai recipe;
endif

if (Role kitchen/barista stock check?) then (ya)
  :Buka stock check/kitchen station;
  if (Butuh move to kitchen?) then (ya)
    :Pilih batch master inventory;
    :Move to kitchen;
    :Update inventory_batches dan inventory_items;
    :Insert kitchen_station_batches dan kitchen_station_movements;
  endif
  if (Butuh opened ingredient?) then (ya)
    :Open ingredient untuk bahan bulk/informal;
    :Catat kitchen_station_movements dan usage history;
  endif
  if (Ada waste/used up/report?) then (ya)
    :Submit stock report;
    :Mark waste atau mark used up;
    :Insert stock_reports dan movement terkait;
  endif
  if (Testing food/drink/ingredient?) then (ya)
    :Pilih test menu atau test ingredient;
    :Catat penggunaan sebagai COGS/usage history;
  endif
endif

if (Selesai shift?) then (ya)
  :Submit shift closing/cash closing bila diwajibkan;
  :Clock out;
endif

:Pantau staff notification;
stop
@enduml

@startuml
title Activity Diagram - Customer

start
if (Customer dari QR meja?) then (ya)
  :Scan QR table;
  :Validasi token meja;
  :Mulai table_session;
else (tidak)
  :Buka customer menu biasa;
endif

if (Customer login/register?) then (ya)
  :Login/register customer;
  :Sync profile customer;
endif

:Lihat menu dan bundle aktif;
if (Pilih variant?) then (ya)
  :Pilih variant option;
endif

:Masukkan item ke cart;
if (Pakai reward?) then (ya)
  :Buka rewards;
  :Redeem reward;
  :Apply reward ke checkout;
endif

:Checkout order;
:Simpan orders dan order_items;
if (Bayar QRIS?) then (ya)
  :Tampilkan QRIS;
  :Konfirmasi pembayaran di web;
  :Simpan payment_transactions;
endif
:Customer menunggu proses;

if (Ingin cek status?) then (ya)
  :Buka order tracking;
  :Lihat status order;
endif

if (Selesai makan / sesi berakhir?) then (ya)
  :End table_session;
endif

stop
@enduml
